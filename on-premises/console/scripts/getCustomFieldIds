
/*
  MADE BY LOUIS GOODNEWS
  
  This code will create a list of strings in the style of "String customfieldName = 'customfield_10000;'" as an easy way to pull all customfield ids from your instance
  to easily reference them in further srcipts via copy and paste. enjoy!
*/

import com.atlassian.jira.component.ComponentAccessor;

import com.atlassian.jira.issue.fields.CustomFieldManager;
import com.atlassian.jira.issue.fields.CustomField;

import org.apache.log4j.Logger;
import org.apache.log4j.Level;

Logger logger = Logger.getLogger("de.louis.scriptrunner.console.getCustomFieldIds");
logger.setLevel(Level.DEBUG);

StringBuilder innerStringBuilder = new StringBuilder();
LinkedList<String> result = new LinkedList();

LinkedList<CustomField> customFields = ComponentAccessor.getCustomFieldManager().getCustomFieldObjects();

customFields.each { CustomField customField ->
try{


    if (customField.getName().contains(" ")) {

        String[] customFieldNameArray = customField.getName().split(" ");
        for (Integer i = 0; i < customFieldNameArray.size(); i++) {
            
            if (i == 0) {

                innerStringBuilder.append( new String( customFieldNameArray[i].toLowerCase() ) );
            } else {

                innerStringBuilder.append( new String( customFieldNameArray[i].substring(0, 1) + customFieldNameArray[i].substring(1) ) );
            }
        }
        customFields.add( innerStringBuilder.append( new String("String ${customField.getName()} = '${customField.getId()}';") ) );
        innerStringBuilder.delete(0, innerStringBuilder.length());        
    } else {

        result.add( new String("String ${ customField.getName() } = '${ customField.getId() }';") );
    }
} catch (Exception e) {

    logger.error("Ran into exception ${e} while running code!");
    return;
}
};

return ["size": customFields.size(), "fields": result];
